# =============================================================================
# Colorbar Engraving Admin Dashboard - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# --- Shopify API ---
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Server ---
PORT=5000

# --- Default Admin Credentials (first-run only) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Email Notifications (Office 365 SMTP) ---
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=your-email@company.com
EMAIL_PASS=your-email-password
EMAIL_TO=recipient1@company.com,recipient2@company.com

# --- Dashboard URL (used in email templates) ---
DASHBOARD_URL=http://localhost:3000
