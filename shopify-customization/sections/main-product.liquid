<!-- NEW: Engraving link under Buy buttons -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  var mainBuyButtons = document.querySelector('.buy-buttons');

  if (mainBuyButtons && !document.getElementById('engrave-link-wrap')) {
    var wrap = document.createElement('div');
    wrap.id = 'engrave-link-wrap';
    wrap.style.textAlign = 'center';
    wrap.style.marginTop = '16px';

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = 'Make It Truly Yours - Engrave This';
    btn.style.background = 'none';
    btn.style.border = '0';
    btn.style.padding = '0';
    btn.style.color = '#5c2b17';
    btn.style.fontSize = '16px';
    btn.style.fontWeight = '500';
    btn.style.textDecoration = 'underline';
    btn.style.cursor = 'pointer';

    wrap.appendChild(btn);
    mainBuyButtons.insertAdjacentElement('afterend', wrap); 

    btn.addEventListener('click', function () {
      const scrollY = window.scrollY;

      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.width = '100%';

      document.getElementById('engrave-modal-backdrop').style.display = 'flex';
      document.body.setAttribute('data-scroll-y', scrollY);
    });
  }
});
