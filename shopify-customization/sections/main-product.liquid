<script>
document.addEventListener('DOMContentLoaded', function () {

  const engraveAddBtn = document.querySelector('#engrave-modal-backdrop .btn-primary');
  if (!engraveAddBtn) return;

  const variants = {{ product.variants | json }};

  function getSelectedVariant() {
    const variantInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
    if (!variantInput || !variantInput.value) return null;
    return variants.find(v => v.id == variantInput.value);
  }

  function updateEngraveAddButtonState() {
    const variant = getSelectedVariant();
    if (!variant) return;

    if (variant.available === false) {
      engraveAddBtn.disabled = true;
      engraveAddBtn.style.opacity = '0.5';
      engraveAddBtn.style.cursor = 'not-allowed';
      engraveAddBtn.textContent = 'Out of Stock';
    } else {
      engraveAddBtn.disabled = false;
      engraveAddBtn.style.opacity = '1';
      engraveAddBtn.style.cursor = 'pointer';
      engraveAddBtn.textContent = 'Add';
    }
  }

  document.addEventListener('click', function (e) {
    if (
      e.target &&
      e.target.textContent &&
      e.target.textContent.toLowerCase().includes('engrave')
    ) {
      setTimeout(updateEngraveAddButtonState, 200);
    }
  });

  document.addEventListener('change', function (e) {
    if (e.target.matches('input[type="radio"][name^="globo-option"]')) {
      setTimeout(updateEngraveAddButtonState, 150);
    }
  });

  // ===== GENERATE PREVIEW DATA FUNCTION =====
  function generateEngravingPreviewData() {
    const editable = document.querySelector('.eng-bubble-input');
    const fontEl = document.querySelector('.eng-font-tab.is-selected');
    const font = fontEl ? fontEl.innerText.trim() : 'Futura-Thin';
    const productImg = document.querySelector('.engrave-base');
    const productImg2 = document.querySelector('.eng-second-image-wrap img');
    const shadeText = document.querySelector('#engrave-modal-backdrop .eng-shade-pill span:last-child');
    const shadeName = shadeText ? shadeText.textContent.trim() : 'N/A';
    
    let previewData = {
      text: '',
      characters: [],
      font: font,
      productImage: productImg ? productImg.src : '',
      productImage2: productImg2 ? productImg2.src : '',
      shade: shadeName,
      textTop: '{{ text_top }}',
      textLeft: '{{ text_left }}',
      textSize: '{{ text_size }}',
      motifMargin: '{{ motif_margin }}',
      textTop2: '{{ text_top_2 }}',
      textLeft2: '{{ text_left_2 }}',
      textSize2: '{{ text_size_2 }}',
      motifMargin2: '{{ motif_margin_2 }}',
      engravingTextOn: '{{ engrave_text_on }}',
      hasSecondImage: {{ has_second_image }},
      image2Width: '{{ image_2_width }}',
      timestamp: new Date().toISOString(),
      version: '3.0'
    };
    
    let charIndex = 0;
    editable.childNodes.forEach(node => {
      if (node.nodeType === Node.ELEMENT_NODE && node.classList.contains('Emotifontfamily')) {
        const motifChar = node.textContent.trim();
        previewData.text += motifChar;
        previewData.characters.push({
          char: motifChar, 
          isMotif: true,
          index: charIndex++
        });
      } else if (node.nodeType === Node.TEXT_NODE) {
        const chars = node.nodeValue.toUpperCase();
        for (const ch of chars) {
          if (ch !== '\n' && ch !== '\r' && ch !== '\u200B') {
            previewData.text += ch;
            previewData.characters.push({
              char: ch, 
              isMotif: false,
              index: charIndex++
            });
          }
        }
      }
    });
    
    return JSON.stringify(previewData);
  }

  /* ===== ADD TO CART HANDLER ===== */
  engraveAddBtn.addEventListener('click', function () {

    if (engraveAddBtn.disabled) return;

    const productForm = document.getElementById('{{ product_form_id }}');
    if (!productForm) return;

    const variant = getSelectedVariant();
    if (!variant || variant.available === false) return;

    const editable = document.querySelector('.eng-bubble-input');
    if (!editable) return;

    // ===== BUILD ENGRAVING TEXT (TYPED LETTERS ONLY) =====
    let engravingText = '';
    editable.childNodes.forEach(node => {
      if (node.nodeType === Node.TEXT_NODE) {
        engravingText += node.nodeValue.toUpperCase().replace(/\u200B/g, '');
      }
    });
    engravingText = engravingText.trim();

    // ===== BUILD FULL STRING (TEXT + MOTIFS COMBINED) =====
    let fullEngravingString = '';
    editable.childNodes.forEach(node => {
      if (
        node.nodeType === Node.ELEMENT_NODE &&
        node.classList.contains('Emotifontfamily')
      ) {
        fullEngravingString += node.textContent.trim();
      } else if (node.nodeType === Node.TEXT_NODE) {
        fullEngravingString += node.nodeValue.toUpperCase().replace(/\u200B/g, '');
      }
    });
    fullEngravingString = fullEngravingString.trim();

    // ===== EXTRACT MOTIFS =====
    const motifs = [];
    editable.childNodes.forEach(node => {
      if (
        node.nodeType === Node.ELEMENT_NODE &&
        node.classList.contains('Emotifontfamily')
      ) {
        const motifChar = node.textContent.trim();
        if (motifChar) {
          motifs.push(motifChar);
        }
      }
    });

    // ===== VALIDATION =====
    if (!fullEngravingString) {
      alert('Please enter engraving text or select motifs');
      return;
    }

    // ===== GET FONT =====
    const fontEl = document.querySelector('.eng-font-tab.is-selected');
    const engravingFont = fontEl ? fontEl.innerText.trim() : 'Default';

    // ===== GET SHADE =====
    const shadeText = document.querySelector('#engrave-modal-backdrop .eng-shade-pill span:last-child');
    const shadeName = shadeText ? shadeText.textContent.trim() : 'N/A';

    /* ===== REMOVE OLD PROPERTIES ===== */
    productForm.querySelectorAll('[data-engraving]').forEach(el => el.remove());

    /* ===== ADD LINE ITEM PROPERTIES ===== */
    function addProp(label, value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = `properties[${label}]`;
      input.value = value;
      input.setAttribute('data-engraving', 'true');
      productForm.appendChild(input);
    }

    addProp('Engraving', 'Yes');
    addProp('Engraving Text', fullEngravingString);
    addProp('Engraving Font', engravingFont);
    addProp('Shade', shadeName);
    if (motifs.length > 0) {
      addProp('Motifs', motifs.join(','));
    }
    
    // ===== CRITICAL: ADD UNDERSCORE TO HIDE FROM CART/CHECKOUT =====
    const previewData = generateEngravingPreviewData();
    addProp('_Preview Data', previewData);
    
    /* ===== SUBMIT FORM ===== */
    productForm.submit();
  });

});
</script>
