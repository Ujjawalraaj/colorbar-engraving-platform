<!-- JS: handles contenteditable input, motif insertion as visible motifs, counting, preview -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  const fontTabs     = document.querySelectorAll('.eng-font-tab');
  const motifs       = Array.from(document.querySelectorAll('.emojiMotif'));
  const editable     = document.querySelector('.eng-bubble-input');
  const lipText      = document.querySelector('.eng-lip-text');
  const lipText2     = document.querySelector('.eng-lip-text-2');  // null if no second image

  // Maximum characters allowed
  const MAX_CHARS = 12;

  // Which characters in your mapping are motif glyphs
  const motifChars = new Set(['m','i','c','p','9','r','7','H','A','✡','♡']);

  // ===== STATE: source of truth (never read from DOM) =====
  let tokens = [];     // [{type:'char',ch:'N'}, {type:'motif',ch:'♡'}, ...]
  let cursorPos = 0;   // index in tokens array where cursor sits

  // ===== RENDER: build DOM from state =====
  function render() {
    editable.innerHTML = '';
    for (const t of tokens) {
      if (t.type === 'motif') {
        const s = document.createElement('span');
        s.className = 'Emotifontfamily';
        s.contentEditable = 'false';
        s.textContent = t.ch;
        editable.appendChild(s);
      } else {
        editable.appendChild(document.createTextNode(t.ch));
      }
    }
    // Trailing zero-width space so cursor can sit after last motif
    const last = editable.lastChild;
    if (!last || last.nodeType === Node.ELEMENT_NODE) {
      editable.appendChild(document.createTextNode('\u200B'));
    }
    updateEmptyClass();
    setCaret(cursorPos);
    updateEngravingPreview();
  }

  // ===== SET CARET in DOM at a token index =====
  function setCaret(pos) {
    editable.focus();
    let acc = 0;
    const children = Array.from(editable.childNodes);
    const range = document.createRange();

    for (let i = 0; i < children.length; i++) {
      const node = children[i];
      if (node.nodeType === Node.TEXT_NODE) {
        const raw = node.nodeValue || '';
        const realLen = [...raw].filter(c => c !== '\u200B').length;
        if (acc + realLen >= pos) {
          let needed = pos - acc;
          let offset = 0;
          let counted = 0;
          for (let j = 0; j < raw.length; j++) {
            if (counted >= needed) break;
            if (raw[j] !== '\u200B') counted++;
            offset++;
          }
          range.setStart(node, offset);
          range.collapse(true);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
          return;
        }
        acc += realLen;
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        acc += 1;
        if (acc >= pos) {
          range.setStart(editable, i + 1);
          range.collapse(true);
          const sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
          return;
        }
      }
    }
    // Fallback: end
    const lastChild = editable.lastChild;
    if (lastChild && lastChild.nodeType === Node.TEXT_NODE) {
      range.setStart(lastChild, lastChild.nodeValue.length);
    } else {
      range.selectNodeContents(editable);
    }
    range.collapse(false);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
  }

  // ===== READ CARET from DOM (only used on click/tap) =====
  function readCaretFromDOM() {
    const sel = window.getSelection();
    if (!sel || sel.rangeCount === 0) return cursorPos;
    const range = sel.getRangeAt(0);
    const container = range.startContainer;
    const offset = range.startOffset;

    let count = 0;
    const children = Array.from(editable.childNodes);

    for (let i = 0; i < children.length; i++) {
      const node = children[i];

      // Caret is directly in editable between child nodes
      if (container === editable && i === offset) return count;

      if (node.nodeType === Node.TEXT_NODE) {
        if (node === container) {
          const before = (node.nodeValue || '').slice(0, offset);
          return count + [...before].filter(c => c !== '\u200B').length;
        }
        count += [...(node.nodeValue || '')].filter(c => c !== '\u200B').length;
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        if (node === container || node.contains(container)) return count + 1;
        count += 1;
      }
    }

    if (container === editable) return count;
    return Math.min(count, tokens.length);
  }

  // Update preview overlay
  function updateEngravingPreview() {
    let html = '';
    for (const t of tokens) {
      if (t.type === 'motif') {
        html += '<span class="Emotifontfamily">'+ escapeHtml(t.ch) +'</span>';
      } else {
        const display = t.ch === ' ' ? '&nbsp;' : escapeHtml(t.ch.toUpperCase());
        html += '<span class="plain-char">'+ display +'</span>';
      }
    }
    const output = (html.length ? html : '\u00A0');
    if (lipText) lipText.innerHTML = output;
    if (lipText2) lipText2.innerHTML = output;
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function(m){
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m];
    });
  }

  function updateEmptyClass() {
    if (tokens.length === 0) {
      editable.classList.add('empty');
    } else {
      editable.classList.remove('empty');
    }
  }

  // ===== KEYBOARD: intercept ALL keys, update state, re-render =====
  editable.addEventListener('keydown', function(e){
    if (e.key === 'Enter') { e.preventDefault(); return false; }

    // Backspace: delete token before cursor
    if (e.key === 'Backspace') {
      e.preventDefault();
      if (cursorPos > 0 && tokens.length > 0) {
        tokens.splice(cursorPos - 1, 1);
        cursorPos--;
        render();
      }
      return false;
    }

    // Delete: delete token after cursor
    if (e.key === 'Delete') {
      e.preventDefault();
      if (cursorPos < tokens.length) {
        tokens.splice(cursorPos, 1);
        render();
      }
      return false;
    }

    // Arrow keys: move cursor without re-rendering
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      if (cursorPos > 0) { cursorPos--; setCaret(cursorPos); }
      return false;
    }
    if (e.key === 'ArrowRight') {
      e.preventDefault();
      if (cursorPos < tokens.length) { cursorPos++; setCaret(cursorPos); }
      return false;
    }
    if (e.key === 'Home') {
      e.preventDefault();
      cursorPos = 0; setCaret(0);
      return false;
    }
    if (e.key === 'End') {
      e.preventDefault();
      cursorPos = tokens.length; setCaret(cursorPos);
      return false;
    }

    // Select all (Ctrl+A / Cmd+A): let browser handle
    if ((e.ctrlKey || e.metaKey) && e.key === 'a') return;

    // Printable character: insert at cursor
    if (e.key.length === 1 && !e.ctrlKey && !e.metaKey) {
      e.preventDefault();
      if (tokens.length >= MAX_CHARS) return false;
      tokens.splice(cursorPos, 0, {type: 'char', ch: e.key.toUpperCase()});
      cursorPos++;
      render();
      return false;
    }
  });

  // ===== PASTE: insert pasted text at cursor =====
  editable.addEventListener('paste', function(e){
    e.preventDefault();
    const text = (e.clipboardData || window.clipboardData).getData('text') || '';
    const chars = [...text].filter(c => c !== '\n' && c !== '\r');
    for (const ch of chars) {
      if (tokens.length >= MAX_CHARS) break;
      tokens.splice(cursorPos, 0, {type: 'char', ch: ch.toUpperCase()});
      cursorPos++;
    }
    render();
  });

  // ===== INPUT: safety net for mobile/IME (shouldn't normally fire) =====
  editable.addEventListener('input', function(e){
    // Re-read what's in the DOM, sync to state
    const newTokens = [];
    for (const node of Array.from(editable.childNodes)) {
      if (node.nodeType === Node.ELEMENT_NODE) {
        const txt = node.textContent || '';
        for (const ch of [...txt]) {
          if (ch === '\u200B') continue;
          newTokens.push({type: 'motif', ch});
        }
      } else if (node.nodeType === Node.TEXT_NODE) {
        const txt = node.nodeValue || '';
        for (const ch of [...txt]) {
          if (ch === '\n' || ch === '\r' || ch === '\u200B') continue;
          newTokens.push({type: 'char', ch: ch.toUpperCase()});
        }
      }
    }
    // Enforce MAX_CHARS
    tokens = newTokens.slice(0, MAX_CHARS);
    cursorPos = Math.min(readCaretFromDOM(), tokens.length);
    render();
  });

  // ===== CLICK/TAP: reposition cursor from DOM selection =====
  editable.addEventListener('mouseup', function(){
    setTimeout(function(){
      cursorPos = readCaretFromDOM();
    }, 0);
  });
  editable.addEventListener('touchend', function(){
    setTimeout(function(){
      cursorPos = readCaretFromDOM();
    }, 0);
  });

  // ===== MOTIF CLICK: insert motif at cursor =====
  motifs.forEach(motif => {
    motif.addEventListener('click', () => {
      motifs.forEach(m => m.classList.remove('is-selected'));
      motif.classList.add('is-selected');
      const ch = (motif.textContent || '').trim();
      if (!ch) return;
      if (tokens.length >= MAX_CHARS) return;
      tokens.splice(cursorPos, 0, {type: 'motif', ch});
      cursorPos++;
      render();
    });
  });

  // Font tab — apply to both overlays
  fontTabs.forEach(tab=>{
    tab.addEventListener('click',()=>{
      fontTabs.forEach(t=>t.classList.remove('is-selected'));
      tab.classList.add('is-selected');

      const txt = (tab.textContent || "").trim().toLowerCase();
      let fontClass = "";
      if (txt.includes("futura")) {
        fontClass = "font-futura";
      } else if (txt.includes("rockwell")) {
        fontClass = "font-rockwell";
      } else if (txt.includes("avant")) {
        fontClass = "font-avant";
      } else {
        if (txt.includes("english") || txt.includes("script")) {
          fontClass = "font-english-script";
        } else {
          fontClass = "";
        }
      }

      const allFontClasses = ["font-futura","font-rockwell","font-avant","font-english-script"];

      editable.classList.remove(...allFontClasses);
      if (lipText) lipText.classList.remove(...allFontClasses);
      if (lipText2) lipText2.classList.remove(...allFontClasses);

      if (fontClass) {
        editable.classList.add(fontClass);
        if (lipText) lipText.classList.add(fontClass);
        if (lipText2) lipText2.classList.add(fontClass);
      }
      render();
    });
  });

  // Initial state: empty
  tokens = [];
  cursorPos = 0;
  render();
});
</script>


<script>
document.addEventListener('DOMContentLoaded', function () {

  function getCheckedShadeRadio() {
    return document.querySelector(
      '.product input[type="radio"][name^="globo-option"]:checked'
    );
  }

  function getLabelFromRadio(radio) {
    if (!radio || !radio.id) return null;
    return document.querySelector('label[for="' + radio.id + '"]');
  }

  function extractRGB(bg) {
    if (!bg) return null;
    const match = bg.match(/rgb\([^)]+\)/);
    return match ? match[0] : null;
  }

  function getShadeName() {
    const input = document.querySelector('input[name="id"]');
    if (!input) return null;

    const variants = {{ product.variants | json }};
    const variant = variants.find(v => v.id == input.value);
    if (!variant) return null;

    const options = {{ product.options | json }};
    const index = options.findIndex(o => o.toLowerCase() === 'shade');
    return index > -1 ? variant.options[index] : null;
  }

  function syncShadeToEngravingModal() {
    const modal = document.getElementById('engrave-modal-backdrop');
    if (!modal || modal.style.display === 'none') return;

    const swatch = modal.querySelector('.eng-shade-swatch');
    const text   = modal.querySelector('.eng-shade-pill span:last-child');
    if (!swatch || !text) return;

    const shadeName = getShadeName();
    if (shadeName) text.textContent = shadeName;

    const radio = getCheckedShadeRadio();
    const label = getLabelFromRadio(radio);
    if (!label) return;

    const bg = label.style.background;
    const rgb = extractRGB(bg);
    if (!rgb) return;

    swatch.style.background = rgb;
  }

  document.addEventListener('click', function (e) {
    if (
      e.target &&
      e.target.textContent &&
      e.target.textContent.toLowerCase().includes('engrave')
    ) {
      setTimeout(syncShadeToEngravingModal, 200);
    }
  });

});
</script>
